{
  "name": "airticket-app",
  "private": true,
  "version": "0.1.0",
  "description": "Professional Ionic Vue Capacitor mobile app boilerplate for AirTicket App.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run type-check && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "cypress run",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "build:android": "npm run build && cap sync android && cd android && gradlew.bat assembleDebug",
    "build:ios": "npm run build && cap sync ios && cap open ios",
    "ionic:build": "npm run build",
    "ionic:serve": "npm run dev -- --open"
  },
  "dependencies": {
    "@capacitor/android": "8.4.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.0",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.4.0",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@ionic/vue": "8.8.9",
    "@ionic/vue-router": "8.8.9",
    "ionicons": "8.0.13",
    "vue": "3.5.35",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.0",
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.8",
    "@vue/compiler-sfc": "3.5.35",
    "@vue/test-utils": "2.4.11",
    "cypress": "15.16.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "sass": "1.100.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.4"
  }
}
